{
  "name": "eslint-plugin-react-effectless",
  "version": "1.0.9",
  "license": "MIT",
  "type": "module",
  "keywords": [
    "eslint",
    "eslint-plugin",
    "react",
    "useEffect",
    "effectless",
    "lint",
    "hooks"
  ],
  "engines": {
    "node": ">=22.0.0",
    "npm": ">=10.0.0"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "vite build",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:ui": "vitest --ui"
  },
  "peerDependencies": {
    "eslint": ">=8.0.0"
  },
  "devDependencies": {
    "vite": "8.0.3",
    "vite-plugin-dts": "4.5.4"
  }
}
